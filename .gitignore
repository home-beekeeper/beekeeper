# Build output
/dist/
/bin/

# Compiled binaries / objects
*.exe
*.exe~
*.dll
*.so
*.dylib
/beekeeper
/beekeeper.exe

# Go test / coverage artifacts
*.test
*.out
coverage.txt
coverage.html

# Go workspace files
go.work
go.work.sum

# Editor / OS cruft
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Local agent tooling state — machine-local config + generated caches, never commit.
# .claude/ holds settings.local.json, worktrees, and a scheduled-tasks lock;
# .understand-anything/ is the understand-anything knowledge-graph cache (multi-MB).
.claude/
.understand-anything/

# === Node / Web toolchain (v1.3.0 web/ workspace) ===
# Repo-root pnpm virtual store (symlinks only), created by `pnpm install`.
# This is expected pnpm-workspace behavior — do NOT delete node_modules/.
# (The existing `*.out` rule above matches the .out extension, not the out/ dir,
#  so web/out/ below is still required.)
node_modules/
# Next.js build artifacts (web/.gitignore also covers these from inside web/).
web/.next/
web/out/
# fumadocs-mdx generated types (created by `next build` once Phase 13 installs it).
# No trailing slash so `git check-ignore web/.source` matches before the dir exists.
web/.source
web/
